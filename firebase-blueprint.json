{
  "entities": {
    "Contract": {
      "title": "Contract",
      "description": "A vehicle rental contract generated by the system.",
      "type": "object",
      "properties": {
        "locatarioNome": { "type": "string", "description": "Full name of the tenant" },
        "locatarioCpf": { "type": "string", "description": "CPF of the tenant" },
        "locatarioRg": { "type": "string", "description": "RG of the tenant" },
        "locatarioEndereco": { "type": "string", "description": "Full address of the tenant" },
        "locatarioTelefone": { "type": "string", "description": "Phone number of the tenant" },
        "locatarioEmail": { "type": "string", "description": "Email of the tenant" },
        "veiculoMarca": { "type": "string", "description": "Vehicle brand" },
        "veiculoModelo": { "type": "string", "description": "Vehicle model" },
        "veiculoCor": { "type": "string", "description": "Vehicle color" },
        "veiculoCombustivel": { "type": "string", "description": "Vehicle fuel type" },
        "veiculoPlaca": { "type": "string", "description": "Vehicle license plate" },
        "veiculoRenavam": { "type": "string", "description": "Vehicle RENAVAM" },
        "veiculoChassis": { "type": "string", "description": "Vehicle chassis number" },
        "veiculoNomeFinanciado": { "type": "string", "description": "Owner/Financed name on vehicle document" },
        "veiculoDocumentacao": { "type": "string", "description": "Vehicle documentation status" },
        "valorEntrada": { "type": "number", "description": "Down payment amount" },
        "valorParcela": { "type": "number", "description": "Installment amount" },
        "numeroParcelas": { "type": "number", "description": "Number of installments" },
        "dataVencimentoPrimeira": { "type": "string", "description": "First installment due date" },
        "diaVencimento": { "type": "number", "description": "Monthly due day" },
        "dataEntrega": { "type": "string", "description": "Vehicle delivery date" },
        "horaEntrega": { "type": "string", "description": "Vehicle delivery time" },
        "localEntrega": { "type": "string", "description": "Vehicle delivery location" },
        "userId": { "type": "string", "description": "UID of the user who created the contract" },
        "createdAt": { "type": "object", "description": "Timestamp of creation" }
      },
      "required": ["locatarioNome", "locatarioCpf", "veiculoPlaca", "userId", "createdAt"]
    }
  },
  "firestore": {
    "/contracts/{contractId}": {
      "schema": "Contract",
      "description": "Collection of vehicle rental contracts."
    }
  }
}
